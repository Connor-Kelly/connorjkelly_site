---
import { getCollection } from 'astro:content';
import SidebarLayout from '../../layouts/SidebarLayout.astro';
const blog_posts = await getCollection('blog');
---

<SidebarLayout>
	<div class='flex flex-col pt-8'>
		<div class='text-center prose mx-auto'>
			<h1>Welcome to my blog!</h1>
		</div>
		<div class='container mx-auto p-8'>
			<div class='grid grid-cols-2 gap-4 xl:grid-cols-3'>
				{
					blog_posts.map((post) => (
						<a href={`/blog/${post.id}`} class='even:translate-y-16'>
							<div class='card border-primary border-6 bg-base-100 ring-secondary ring-4'>
								<div class='card-body'>
									<p class='text-2xl font-bold'>{post.data.title}</p>
									<div class='flex gap-1'>
										{post.data.tags.map((t) => (
											<div class='badge badge-sm badge-primary'>{t}</div>
										))}
									</div>
									<p class='line-clamp-3'>{post.data.description}</p>
								</div>
							</div>
						</a>
					))
				}
			</div>
		</div>
	</div>
</SidebarLayout>
