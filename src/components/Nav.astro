---
import '../styles/global.css';

// required change due to bug described here: https://github.com/withastro/astro/issues/12928
// import { Ellipsis, Sun, Moon } from '@lucide/astro';
import Sun from '@lucide/astro/icons/sun';
import Moon from '@lucide/astro/icons/moon';

interface Props {
	breadcrumbs: String[] | undefined;
}
const { breadcrumbs } = Astro.props;
---

<div class='flex h-8 shadow-sm p-4 sticky top-0 justify-between w-full items-center min-h-8 bg-base-100 z-50'>
	<div class='breadcrumbs text-sm pr-4 ml-2 mb-1'>
		{
			breadcrumbs && (
				<ul>
					<li>
						<a href='/'>/</a>
					</li>

					{breadcrumbs
						.filter((b) => b.length > 0)
						.map((breadcrumb, i, arr) => {
							return (
								<li>
									<a href={`/${arr.slice(0, i + 1).join('/')}`}>{breadcrumb}</a>
								</li>
							);
						})}
				</ul>
			)
		}
	</div>
	<div class=''>
		<label class='swap swap-rotate'>
			<input type='checkbox' data-toggle-theme='dark,light' class='theme-controller' id='theme-controller' />
			<Sun class='swap-on' />
			<Moon class='swap-off' />
		</label>
	</div>
</div>
